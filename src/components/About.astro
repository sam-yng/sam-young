---
import cloud from "../assets/sam-cloud.png";
---

<section
	class="relative overflow-hidden border-t-2 border-ink-900 bg-ink-900 text-paper-100"
	id="about"
	aria-labelledby="about-title"
>
	<img
		class="pointer-events-none absolute top-[-3%] left-[3%] h-auto w-[clamp(82px,10vw,145px)] animate-cloud-bob-flip drop-shadow-[0_0_34px_rgb(214_255_63_/_30%)] motion-reduce:animate-none motion-reduce:[transform:scaleX(-1)]"
		src={cloud.src}
		width={cloud.width}
		height={cloud.height}
		alt=""
		aria-hidden="true"
	/>
	<div class="mx-auto max-w-[var(--container)] px-[var(--gutter)] py-[clamp(80px,10vw,140px)]">
		<p class="eyebrow mb-8 text-volt-500" data-reveal>// about</p>
		<h2
			id="about-title"
			class="mb-10 max-w-[18ch] text-paper-100 tracking-[var(--tracking-tight)] [font:800_clamp(36px,5.5vw,64px)/1.04_var(--font-display)]"
			data-reveal
		>
			I care about the <span class="text-volt-500">seam</span> between craft and code.
		</h2>
		<div
			class="grid grid-cols-2 gap-[clamp(24px,4vw,56px)] max-[640px]:grid-cols-1"
		>
			<p class="m-0 text-ink-200 [font:var(--type-body-lg)]" data-reveal>
				I work where design and engineering overlap, turning rough ideas into interfaces that are fast, considered, and a little bit fun.
			</p>
			<p class="m-0 text-ink-200 [font:var(--type-body-lg)]" data-reveal>
				I like motion that means something, type that does the heavy lifting, and getting the thing into people’s hands.
			</p>
		</div>
		<div class="mt-[clamp(32px,5vw,64px)]" data-reveal>
			<p class="mb-4 text-ink-400 [font:var(--type-mono-meta)]">this site =</p>
			<ul
				class="m-0 flex flex-wrap gap-[10px] p-0 [list-style:none]"
				aria-label="Technology used to build this site"
			>
				<li
					class="rounded-pill border-[1.5px] border-ink-600 px-[13px] py-[7px] text-paper-100 [font:500_var(--text-xs)/1_var(--font-mono)] [letter-spacing:var(--tracking-mono)]"
				>
					Astro
				</li>
				<li
					class="rounded-pill border-[1.5px] border-ink-600 px-[13px] py-[7px] text-paper-100 [font:500_var(--text-xs)/1_var(--font-mono)] [letter-spacing:var(--tracking-mono)]"
				>
					GSAP
				</li>
				<li
					class="rounded-pill border-[1.5px] border-ink-600 px-[13px] py-[7px] text-paper-100 [font:500_var(--text-xs)/1_var(--font-mono)] [letter-spacing:var(--tracking-mono)]"
				>
					Lenis
				</li>
			</ul>
		</div>
	</div>
</section>
