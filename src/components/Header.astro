---
import Logo from "./Logo.astro";
---

<header class="site-header" data-site-header>
	<a class="site-header__logo" href="#top" aria-label="Sam Young, back to top">
		<Logo />
	</a>
	<nav aria-label="Primary navigation">
		<a href="#work">Work</a>
		<a href="#about">About</a>
		<a href="#contact">Contact</a>
	</nav>
</header>

<script>
	const header = document.querySelector<HTMLElement>("[data-site-header]");

	function updateHeader() {
		header?.classList.toggle("is-scrolled", window.scrollY > 30);
	}

	updateHeader();
	window.addEventListener("scroll", updateHeader, { passive: true });
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 14px var(--gutter);
		border-bottom: var(--bw) solid transparent;
		transition:
			background var(--dur-3) var(--ease-out),
			border-color var(--dur-3) var(--ease-out),
			backdrop-filter var(--dur-3) var(--ease-out);
	}

	.site-header.is-scrolled {
		background: rgb(251 248 241 / 82%);
		border-bottom-color: var(--ink-900);
		backdrop-filter: blur(10px);
	}

	.site-header__logo {
		color: inherit;
		text-decoration: none;
	}

	nav {
		display: flex;
		align-items: center;
		gap: clamp(14px, 2.5vw, 30px);
	}

	nav a {
		color: var(--ink-900);
		font: var(--type-mono-label);
		letter-spacing: var(--tracking-mono);
		text-decoration: underline;
		text-decoration-color: transparent;
		text-underline-offset: 4px;
		text-transform: uppercase;
		transition: text-decoration-color var(--dur-1) ease-out;
	}

	nav a:hover {
		text-decoration-color: currentcolor;
	}

	@media (max-width: 480px) {
		.site-header {
			padding-block: 12px;
		}

		nav {
			gap: var(--space-3);
		}

		nav a {
			font-size: 11px;
		}
	}

	@media (max-width: 360px) {
		.site-header__logo :global(.logo__wordmark) {
			display: none;
		}
	}
</style>
