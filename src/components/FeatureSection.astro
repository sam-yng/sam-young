---
interface Props {
	title?: string;
	body?: string;
}

const {
	title = "A feature.",
	body = "This section reveals as it scrolls into view.",
} = Astro.props;
---

<section class="feature">
	<div class="feature__inner">
		<h2>{title}</h2>
		<p>{body}</p>
	</div>
</section>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	gsap.utils.toArray<HTMLElement>('.feature').forEach((section) => {
		gsap.from(section.querySelector('.feature__inner'), {
			scrollTrigger: {
				trigger: section,
				start: 'top 80%',
			},
			y: 60,
			opacity: 0,
			duration: 1,
		});
	});
</script>

<style>
	.feature {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 16px;
	}

	.feature__inner {
		max-width: 640px;
		text-align: center;
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
	}

	.feature h2 {
		font-size: clamp(2rem, 6vw, 4rem);
		margin: 0 0 0.5em;
	}

	.feature p {
		font-size: 1.125rem;
		line-height: 1.6;
		color: #4b5563;
		margin: 0;
	}
</style>
