---
import cloud from "../assets/sam-cloud.png";
import Logo from "./Logo.astro";
---

<footer class="contact" id="contact" aria-labelledby="contact-title">
	<img
		class="contact__cloud"
		src={cloud.src}
		width={cloud.width}
		height={cloud.height}
		alt=""
		aria-hidden="true"
	/>

	<div class="contact__inner">
		<div class="contact__grid">
			<div data-reveal>
				<p class="eyebrow">// got something weird to build?</p>
				<h2 id="contact-title">Let’s<br />make it.</h2>
			</div>

			<div class="contact-card" data-reveal>
				<p class="contact-card__label">// contact route</p>
				<h3>Details coming next.</h3>
				<p>The layout is ready. A real email address or form endpoint still needs to be connected.</p>
				<span class="sticker-button sticker-button--volt" aria-disabled="true">Contact details pending</span>
			</div>
		</div>

		<div class="contact__subfooter">
			<a href="#top" aria-label="Sam Young, back to top"><Logo size={30} /></a>
			<p>© 2026 — built with too much care</p>
		</div>
	</div>
</footer>

<style>
	.contact {
		position: relative;
		overflow: hidden;
		background: var(--paper-100);
		border-top: var(--bw-bold) solid var(--ink-900);
	}

	.contact__cloud {
		position: absolute;
		right: -3%;
		bottom: 4%;
		width: clamp(78px, 10vw, 140px);
		height: auto;
		opacity: 0.92;
		pointer-events: none;
		animation: cloud-bob 4s ease-in-out infinite;
	}

	.contact__inner {
		max-width: var(--container);
		margin: 0 auto;
		padding: clamp(64px, 9vw, 128px) var(--gutter) clamp(28px, 4vw, 40px);
	}

	.contact__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: clamp(32px, 6vw, 72px);
		align-items: center;
	}

	.contact .eyebrow {
		margin-bottom: var(--space-5);
		color: var(--ink-900);
	}

	h2 {
		font: 800 clamp(54px, 8vw, 92px) / 0.94 var(--font-display);
		letter-spacing: var(--tracking-tight);
	}

	.contact-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		padding: clamp(24px, 3vw, 36px);
		background: var(--paper-000);
		border: var(--bw-bold) solid var(--ink-900);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-hard-lg);
	}

	.contact-card__label {
		color: var(--text-muted);
		font: var(--type-mono-label);
		letter-spacing: var(--tracking-caps);
		text-transform: uppercase;
	}

	.contact-card h3 {
		font: 700 clamp(28px, 4vw, 40px) / 1.05 var(--font-display);
		letter-spacing: var(--tracking-snug);
	}

	.contact-card > p:not(.contact-card__label) {
		max-width: 42ch;
		font: var(--type-body);
	}

	.contact-card .sticker-button {
		align-self: stretch;
		margin-top: var(--space-2);
		cursor: not-allowed;
		text-align: center;
	}

	.contact__subfooter {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		margin-top: clamp(48px, 7vw, 88px);
		padding-top: var(--space-6);
		border-top: var(--bw) solid var(--ink-900);
		flex-wrap: wrap;
	}

	.contact__subfooter a {
		color: inherit;
		text-decoration: none;
	}

	.contact__subfooter p {
		font: var(--type-mono-meta);
	}

	@keyframes cloud-bob {
		0%,
		100% {
			transform: translate3d(0, 0, 0) scale(1);
		}

		50% {
			transform: translate3d(0, -9px, 0) scale(1.07);
		}
	}

	@media (max-width: 700px) {
		.contact__grid {
			grid-template-columns: 1fr;
		}

		.contact__cloud {
			bottom: 1%;
			opacity: 0.55;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.contact__cloud {
			animation: none;
		}
	}
</style>
